{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/generate$",
      "dest": "/app.py"
    },
    {
      "src": "^/health$",
      "dest": "/app.py"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/index.html"
    }
  ]
}
